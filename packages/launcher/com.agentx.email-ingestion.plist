<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.agentx.email-ingestion</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/curl</string>
        <string>-sf</string>
        <string>--max-time</string>
        <string>120</string>
        <string>-X</string>
        <string>POST</string>
        <string>http://127.0.0.1:3001/api/email/check</string>
    </array>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>19</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/darrenjones/.agentx/logs/email-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/darrenjones/.agentx/logs/email-launchd.log</string>

    <!-- Run missed jobs when system wakes up -->
    <key>StartInterval</key>
    <integer>86400</integer>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
