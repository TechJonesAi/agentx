{
  "name": "@agentx/web",
  "version": "0.1.0",
  "type": "module",
  "description": "Web UI for AgentX",
  "main": "dist/server/index.js",
  "types": "dist/server/index.d.ts",
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:client": "vite build",
    "dev": "tsc --watch",
    "start": "node dist/serve.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentx/core": "workspace:*",
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.7.3",
    "vite": "^5.0.0"
  }
}
